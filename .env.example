# Example environment variables for seo-benail
# Do NOT commit secrets. Use this file as a template.

# WordPress (existing)
WP_URL=https://stefanodagogle.com
WP_DOMAIN=stefanodagogle.com
WP_USERNAME=admin
WP_APP_PASSWORD=changeme

# LLM / API keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=groq/llama-3.3-70b-versatile

# PrestaShop (add these to GitHub Secrets in production)
# PRESTA_URL: your shop base URL without trailing slash
PRESTA_URL=https://benail.it
# PRESTA_WS_KEY: PrestaShop Webservice key (give read/write to products, images)
PRESTA_WS_KEY=
PRESTA_LANG_ID=1
PRESTA_SHOP_ID=1
PRESTA_CURRENCY=EUR
# When true, the publishing scripts will NOT perform writes to the store
PRESTA_DRY_RUN=true
