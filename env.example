"""Editor/QA agent: grammar, clarity, internal linking suggestions, final pass."""

from crewai import Agent
from agents.llm import get_groq_llm


def build_editor_agent() -> Agent:
    return Agent(
        role="Editor",
        goal=(
            "Perform a final QA pass: fix grammar and clarity issues, "
            "ensure heading structure is logical, and suggest 2-3 natural "
            "internal-link anchor texts relevant to the store's other "
            "likely product/category pages. Output the final, publish-"
            "ready copy."
        ),
        backstory=(
            "You are a precise copy editor with an eye for structure. You "
            "make only necessary changes, preserve the writer's voice, "
            "and never reintroduce any health claims that the Moderator "
            "flagged."
        ),
        llm=get_groq_llm(temperature=0.3),
        verbose=True,
        allow_delegation=False,
    )
